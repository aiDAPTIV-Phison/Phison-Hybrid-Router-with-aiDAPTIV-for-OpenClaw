{
  "id": "hybrid-gateway",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "classifier": {
        "type": "object",
        "properties": {
          "mode": { "type": "string", "enum": ["model", "heuristic"] },
          "baseUrl": { "type": "string" },
          "apiKey": { "type": "string" },
          "model": { "type": "string" },
          "maxLatencyMs": { "type": "number" },
          "cacheEnabled": { "type": "boolean" },
          "cacheTtlSeconds": { "type": "number" },
          "systemPrompt": { "type": "string", "description": "Override the built-in classifier system prompt" },
          "disableThinking": { "type": "boolean" },
          "thinkingStrategy": { "type": "string", "enum": ["auto", "gemma4-raw", "qwen-nothink"] }
        }
      },
      "routing": {
        "type": "object",
        "properties": {
          "policy": { "type": "string", "enum": ["edge-first", "cloud-first", "cost-optimize", "cost-optimize-L1", "cost-optimize-L2", "cost-optimize-L3", "quality-first"] },
          "policy-array": {
            "type": "array",
            "minItems": 5,
            "maxItems": 5,
            "items": { "type": "string", "enum": ["classifier", "edge", "cloud"] },
            "description": "Optional 5-item override for `policy`. Index 0-4 maps to complexity trivial/simple/moderate/complex/expert. Each item must be one of [classifier, edge, cloud]. When valid, `policy` is ignored."
          },
          "policyArray": {
            "type": "array",
            "minItems": 5,
            "maxItems": 5,
            "items": { "type": "string", "enum": ["classifier", "edge", "cloud"] },
            "description": "camelCase alias of `policy-array`."
          },
          "skillRoutes": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "skillPattern": { "type": "string" },
                "forceTier": { "type": "string", "enum": ["classifier", "edge", "cloud"] },
                "preferModel": { "type": "string" },
                "reason": { "type": "string" }
              },
              "required": ["skillPattern"]
            }
          },
          "fallbackEnabled": { "type": "boolean" },
          "bypassPatterns": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Regex patterns (case-insensitive). Prompts matching any pattern bypass routing override."
          }
        }
      },
      "models": {
        "type": "object",
        "properties": {
          "classifier": {
            "type": "object",
            "properties": {
              "provider": { "type": "string" },
              "model": { "type": "string" }
            },
            "required": ["provider", "model"]
          },
          "edge": {
            "type": "object",
            "properties": {
              "provider": { "type": "string" },
              "model": { "type": "string" }
            },
            "required": ["provider", "model"]
          },
          "cloud": {
            "type": "object",
            "properties": {
              "provider": { "type": "string" },
              "model": { "type": "string" }
            },
            "required": ["provider", "model"]
          }
        }
      }
    }
  }
}
